# 基本配置
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_WORKERS=4

# 数据库配置
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app
DB_USER=root
DB_PASSWORD=password

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=3600

# 文件存储配置
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800  # 50MB in bytes
USER_STORAGE_QUOTA=1073741824  # 1GB in bytes
FILE_CLEANUP_DAYS=7
TEMP_FILE_CLEANUP_HOURS=24

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 缓存配置
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300

# 邮件配置
MAIL_SERVER=smtp.googlemail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_DIR=logs

# 日志过滤器配置 - 减少SQL和HTTP请求日志噪音
LOG_FILTER_SQL=true
LOG_FILTER_HTTP=true
LOG_FILTER_STATIC=true
LOG_FILTER_CUSTOM_PATTERNS=
LOG_FILTER_WHITELIST_PATTERNS=ERROR,WARNING,翻译,任务,上传,处理,失败,成功

# 特定日志记录器级别配置
LOG_LEVEL_SQLALCHEMY=WARNING
LOG_LEVEL_WERKZEUG=WARNING
LOG_LEVEL_URLLIB3=WARNING
LOG_LEVEL_REQUESTS=WARNING

# 线程池配置
THREAD_POOL_MAX_WORKERS=32
THREAD_POOL_IO_WORKERS=24
THREAD_POOL_CPU_WORKERS=8
THREAD_POOL_NAME_PREFIX=app

# 任务队列配置
TASK_QUEUE_MAX_CONCURRENT=5
TASK_QUEUE_TIMEOUT=3600
TASK_QUEUE_RETRY_TIMES=3

# HTTP客户端配置
HTTP_CLIENT_MAX_CONNECTIONS=100
HTTP_CLIENT_TIMEOUT=60
HTTP_CLIENT_RETRY_TIMES=3
HTTP_CLIENT_RETRY_DELAY=1