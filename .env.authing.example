# ================================
# FCI AI翻译助手 UAT SSO配置
# Authing身份云 OAuth2/OIDC 配置
# ================================

# ================================
# 基础SSO配置
# ================================

# 启用SSO登录
SSO_ENABLED=true

# SSO提供者类型 (Authing使用OAuth2/OIDC)
SSO_PROVIDER=oauth2

# 自动创建SSO用户
SSO_AUTO_CREATE_USER=true

# SSO用户默认角色
SSO_DEFAULT_ROLE=user

# ================================
# Authing OAuth2/OIDC 配置
# ================================

# Authing应用ID
OAUTH2_CLIENT_ID=683ebc2889ae4d4c1ff7e111

# Authing应用Secret
OAUTH2_CLIENT_SECRET=082339b43a8da9636332e1f4d11111

# Authing授权端点
OAUTH2_AUTHORIZATION_URL=https://sso.rfc-friso.com/683ebc2889ae4d4c1ff7e111/oidc/auth

# Authing令牌端点
OAUTH2_TOKEN_URL=https://sso.rfc-friso.com/683ebc2889ae4d4c1ff7e111/oidc/token

# Authing用户信息端点
OAUTH2_USERINFO_URL=https://sso.rfc-friso.com/683ebc2889ae4d4c1ff7e111/oidc/me

# Authing登出端点
OAUTH2_LOGOUT_URL=https://sso.rfc-friso.com/683ebc2889ae4d4c1ff7e111/oidc/session/end

# OAuth2权限范围
OAUTH2_SCOPE=openid profile email phone

# 生产环境回调URL
OAUTH2_REDIRECT_URI=https://fci-ai-agent-uat.rfc-friso.com/auth/sso/callback

# ================================
# Authing用户属性映射
# ================================

# 用户名映射 (Authing返回username字段)
SSO_ATTR_USERNAME=username

# 邮箱映射
SSO_ATTR_EMAIL=email

# 名字映射
SSO_ATTR_FIRST_NAME=given_name

# 姓氏映射
SSO_ATTR_LAST_NAME=family_name

# 显示名称映射
SSO_ATTR_DISPLAY_NAME=name

# 手机号映射
SSO_ATTR_PHONE=phone_number

# 头像映射
SSO_ATTR_PICTURE=picture

# 用户组映射 (如果Authing配置了组信息)
SSO_ATTR_GROUPS=groups

# ================================
# 开发环境配置
# ================================

# 本地开发时使用的回调URL
# 注释掉上面的OAUTH2_REDIRECT_URI，启用下面的配置
# OAUTH2_REDIRECT_URI=http://localhost:5000/auth/sso/callback

# ================================
# 高级配置
# ================================

# 组到角色的映射 (JSON格式)
# 根据Authing中配置的用户组映射到系统角色
SSO_GROUP_ROLE_MAPPING={"admin": "admin", "administrators": "admin", "users": "user", "translators": "user"}

# 会话配置
SESSION_TIMEOUT=3600
REMEMBER_COOKIE_DURATION=2592000

# 安全配置
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ================================
# Authing API配置 (扩展功能)
# ================================

# Authing Management API 配置 (用于高级用户管理)
# AUTHING_DOMAIN=sso.rfc-friso.com
# AUTHING_USER_POOL_ID=683ebc2889ae4d4c1ff7e111
# AUTHING_APP_SECRET=082339b43a8da9636332e1f4d11111

# Authing GraphQL API端点 (用于复杂查询)
# AUTHING_GRAPHQL_ENDPOINT=https://sso.rfc-friso.com/683ebc2889ae4d4c1ff7e111/graphql/v2

# ================================
# 调试配置
# ================================

# 启用SSO调试日志
SSO_DEBUG=false

# 日志级别
LOG_LEVEL=INFO

# ================================
# 部署说明
# ================================

# 1. 复制此文件为 .env
# 2. 根据环境修改OAUTH2_REDIRECT_URI
# 3. 确保Authing应用中配置了正确的回调URL
# 4. 运行数据库迁移: python migrations/add_sso_fields.py upgrade
# 5. 启动应用: python app.py
# 6. 访问 /auth/login 测试SSO登录

# ================================
# Authing API文档参考
# ================================

# 官方文档: https://api-explorer.authing.cn/
# 主要接口:
# - 登录: /oidc/auth
# - 获取token: /oidc/token  
# - 获取用户信息: /oidc/me
# - 登出: /oidc/session/end
# - 校验token: /api/v2/oidc/validate_token

# ================================
# 故障排除
# ================================

# 常见问题:
# 1. "invalid_client" - 检查CLIENT_ID和CLIENT_SECRET
# 2. "redirect_uri_mismatch" - 检查回调URL配置
# 3. "invalid_scope" - 检查权限范围配置
# 4. "access_denied" - 检查用户权限和应用配置

# 调试步骤:
# 1. 启用SSO_DEBUG=true
# 2. 检查应用日志
# 3. 验证Authing应用配置
# 4. 测试API端点连通性
